#!/bin/bash
# Cohesion CLI v2 - Dual-mode support (local/global)

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GRAY='\033[0;90m'
NC='\033[0m' # No Color

# Installation detection
GLOBAL_COHESION_DIR="$HOME/.cohesion"
GLOBAL_CLAUDE_DIR="$HOME/.claude"
LOCAL_CLAUDE_DIR="./.claude"

# Detect which mode we're in
detect_mode() {
    # Check for FULL local installation (not just a .claude folder from init)
    local has_local=$([ -d "$LOCAL_CLAUDE_DIR" ] && [ -f "$LOCAL_CLAUDE_DIR/settings.json" ] && [ -d "$LOCAL_CLAUDE_DIR/hooks" ] && echo "yes" || echo "no")
    local has_global=$([ -d "$GLOBAL_COHESION_DIR" ] && [ -d "$GLOBAL_CLAUDE_DIR" ] && echo "yes" || echo "no")
    
    if [ "$has_local" = "yes" ]; then
        echo "local"
    elif [ "$has_global" = "yes" ]; then
        echo "global"
    else
        echo "none"
    fi
}

# Get the appropriate directories based on mode
get_directories() {
    local MODE=$(detect_mode)
    
    case $MODE in
        local)
            COHESION_DIR="$LOCAL_CLAUDE_DIR"
            STATE_FILE="$LOCAL_CLAUDE_DIR/state/session.json"
            USING_MODE="local"
            ;;
        global)
            # For global mode, create project-specific state directory
            PROJECT_PATH=$(pwd)
            PROJECT_HASH=$(echo "$PROJECT_PATH" | shasum -a 256 | cut -c1-16)
            COHESION_DIR="$GLOBAL_COHESION_DIR"
            STATE_DIR="$GLOBAL_COHESION_DIR/states/$PROJECT_HASH"
            STATE_FILE="$STATE_DIR/session.json"
            USING_MODE="global"
            
            # Create state directory if it doesn't exist
            if [ ! -d "$STATE_DIR" ]; then
                mkdir -p "$STATE_DIR"
                echo '{"state": "DISCOVER", "timestamp": '$(date +%s)'}' > "$STATE_FILE"
                
                # Update project registry
                PROJECTS_FILE="$GLOBAL_COHESION_DIR/states/projects.json"
                if [ -f "$PROJECTS_FILE" ]; then
                    jq --arg path "$PROJECT_PATH" \
                       --arg hash "$PROJECT_HASH" \
                       --arg time "$(date -Iseconds)" \
                       '.projects[$hash] = {"path": $path, "created": $time}' \
                       "$PROJECTS_FILE" > "$PROJECTS_FILE.tmp" && \
                    mv "$PROJECTS_FILE.tmp" "$PROJECTS_FILE"
                fi
            fi
            ;;
        none)
            echo -e "${RED}Cohesion is not installed!${NC}"
            echo ""
            echo "Install with:"
            echo -e "  ${CYAN}curl -sSL https://cohesion.dev/install | bash${NC}"
            echo "or:"
            echo -e "  ${CYAN}./install.sh${NC}"
            exit 1
            ;;
    esac
}

# Initialize directories
get_directories

show_help() {
    printf "${CYAN}Cohesion DUO Protocol CLI v2.1${NC}\n"
    echo ""
    echo "Usage: cohesion <command> [options]"
    echo ""
    printf "${BLUE}DUO Protocol Commands:${NC}\n"
    echo "  status           Show current DUO state and capabilities"
    echo "  duo-status       Show detailed DUO Protocol status"  
    echo "  reset            Reset to DISCOVER state"
    echo "  safety-check     Verify Cohesion installation integrity"
    echo "  protection-status Show protection system status"
    echo "  history          Show state transition history"
    echo "  stats            Show session statistics"
    echo ""
    printf "${BLUE}Project Commands:${NC}\n"
    echo "  init        Initialize Cohesion in current project"
    echo "  list        List all projects with Cohesion states (global only)"
    echo "  clean       Clean old project states (global only)"
    echo ""
    printf "${BLUE}Installation Commands:${NC}\n"
    echo "  which       Show which installation is being used"
    echo "  upgrade     Upgrade from local to global installation"
    echo "  downgrade   Downgrade from global to local installation"
    echo "  use         Switch between local and global (when both exist)"
    echo "  uninstall   Remove Cohesion installation"
    echo ""
    printf "${BLUE}Other Commands:${NC}\n"
    echo "  help        Show this help message"
    echo ""
    printf "${YELLOW}Current Mode: $USING_MODE${NC}\n"
    if [ "$USING_MODE" = "local" ]; then
        printf "${CYAN}Tip: Run 'cohesion upgrade' to make Cohesion work in all projects!${NC}\n"
    fi
    echo ""
    echo "State Workflow:"
    echo "  DISCOVER -> (get approval) -> UNLEASH -> (complete/needs input) -> DISCOVER/OPTIMIZE"
    echo ""
}

get_state() {
    if [ -f "$STATE_FILE" ]; then
        jq -r '.state // "DISCOVER"' "$STATE_FILE" 2>/dev/null || echo "DISCOVER"
    else
        echo "DISCOVER"
    fi
}

set_state() {
    local NEW_STATE="$1"
    local NOW=$(date +%s)
    mkdir -p "$(dirname "$STATE_FILE")"
    
    if [ -f "$STATE_FILE" ]; then
        jq '. + {"state": "'"$NEW_STATE"'", "timestamp": '"$NOW"'}' "$STATE_FILE" > "${STATE_FILE}.tmp" && mv "${STATE_FILE}.tmp" "$STATE_FILE"
    else
        echo '{"state": "'"$NEW_STATE"'", "timestamp": '"$NOW"'}' > "$STATE_FILE"
    fi
    echo -e "${GREEN}✓${NC} State changed to ${YELLOW}$NEW_STATE${NC}"
}

# DUO Protocol status display
show_duo_status() {
    echo -e "${CYAN}Cohesion DUO Protocol Status${NC}\n"

    local STATE_DIR_FOR_FLAGS
    if [ "$USING_MODE" = "global" ]; then
        STATE_DIR_FOR_FLAGS="$GLOBAL_COHESION_DIR/states/$PROJECT_HASH"
    else
        STATE_DIR_FOR_FLAGS="$LOCAL_CLAUDE_DIR/state"
    fi
    
    local FLAG_DIR="$STATE_DIR_FOR_FLAGS/flags"

    if [ -f "$FLAG_DIR/unleashed" ]; then
        echo -e "State: ${GREEN}UNLEASH ⚡${NC} - Autonomous execution active"
        echo "Unleashed: $(cat "$FLAG_DIR/unleashed")"
    elif [ -f "$FLAG_DIR/optimizing" ]; then
        echo -e "State: ${YELLOW}OPTIMIZE 🤝${NC} - Collaborative consultation mode"
    else
        echo -e "State: ${BLUE}DISCOVER 🔍${NC} - Analysis and planning mode"
    fi

    echo ""
    echo -e "${BLUE}Available Research Tools:${NC}"
    echo "• Read, Grep, Glob - Code analysis"
    echo "• WebSearch, WebFetch - External research"
    echo "• Git inspection commands"

    if [ -f ".claude/context/duo-status.md" ]; then
        echo ""
        echo -e "${BLUE}Full capabilities:${NC} .claude/context/duo-status.md"
    fi
}

duo_reset() {
    local STATE_DIR_FOR_FLAGS
    if [ "$USING_MODE" = "global" ]; then
        STATE_DIR_FOR_FLAGS="$GLOBAL_COHESION_DIR/states/$PROJECT_HASH"
    else
        STATE_DIR_FOR_FLAGS="$LOCAL_CLAUDE_DIR/state"
    fi
    
    local FLAG_DIR="$STATE_DIR_FOR_FLAGS/flags"
    rm -f "$FLAG_DIR/unleashed" "$FLAG_DIR/optimizing" 2>/dev/null
    set_state "DISCOVER"
    echo -e "${GREEN}✓${NC} DUO Protocol reset to DISCOVER state"
}

# Protected directories for safety checks
COHESION_PROTECTED_DIRS=(".claude" ".git" "node_modules" ".next" "build" "dist")

safety_check() {
    echo -e "${CYAN}🛡️  Cohesion Safety Check${NC}\n"

    local ISSUES=0

    # Check .claude directory integrity
    if [ ! -d ".claude" ]; then
        echo -e "${RED}❌ .claude directory missing${NC}"
        ((ISSUES++))
    else
        echo -e "${GREEN}✓${NC} .claude directory present"

        # Check for external contamination
        if find .claude -name "*.tmp" -o -name "*.bak" 2>/dev/null | grep -q .; then
            echo -e "${YELLOW}⚠️${NC}  Temporary files found in .claude"
            ((ISSUES++))
        fi
    fi

    # Verify project files are untouched
    for doc in docs/CONTEXT.md docs/COMMANDS.md README.md; do
        if [ -f "$doc" ]; then
            if [ -r "$doc" ] && [ -s "$doc" ]; then
                echo -e "${GREEN}✓${NC} $doc - accessible and non-empty"
            else
                echo -e "${RED}❌${NC} $doc - may be corrupted"
                ((ISSUES++))
            fi
        fi
    done

    # Check DUO Protocol files
    local DUO_FILES=(".claude/context/duo-status.md" ".claude/state/flags")
    for file in "${DUO_FILES[@]}"; do
        if [ -e "$file" ]; then
            echo -e "${GREEN}✓${NC} $file - DUO Protocol file present"
        else
            echo -e "${YELLOW}⚠️${NC} $file - DUO Protocol file missing"
        fi
    done

    if [ $ISSUES -eq 0 ]; then
        echo -e "\n${GREEN}🛡️  ALL SAFETY CHECKS PASSED${NC}"
    else
        echo -e "\n${YELLOW}⚠️  $ISSUES safety issues detected${NC}"
    fi
}

protection_status() {
    echo -e "${CYAN}🛡️  Cohesion Protection Status${NC}\n"

    echo -e "${BLUE}Protected Directories:${NC}"
    for dir in "${COHESION_PROTECTED_DIRS[@]}"; do
        if [ -d "$dir" ]; then
            echo -e "  ${GREEN}✓${NC} $dir/ - protected and present"
        else
            echo -e "  ${GRAY}○${NC} $dir/ - protected (not present)"
        fi
    done

    echo -e "\n${BLUE}Document Integration Mode:${NC}"
    if [ -f ".claude/context/project-docs-analysis.md" ]; then
        echo -e "  ${GREEN}✓${NC} Read-only integration active"
    elif [ -f ".claude/context/enhancement-summary.md" ]; then
        echo -e "  ${GREEN}✓${NC} Selective enhancement active"
    else
        echo -e "  ${CYAN}→${NC} Minimal documentation mode"
    fi

    echo -e "\n${BLUE}DUO Protocol Status:${NC}"
    if [ -f ".claude/context/duo-status.md" ]; then
        echo -e "  ${GREEN}✓${NC} DUO Protocol context active"
    else
        echo -e "  ${YELLOW}⚠️${NC} DUO Protocol context missing"
    fi

    if [ -d ".claude/state/flags" ]; then
        echo -e "  ${GREEN}✓${NC} Flag-based state management active"
    else
        echo -e "  ${YELLOW}⚠️${NC} Flag-based state management missing"
    fi
}

show_status() {
    echo -e "${BLUE}Cohesion Status${NC}"
    echo "========================="
    
    # Show mode and project info
    echo -e "Mode: ${YELLOW}$USING_MODE${NC}"
    if [ "$USING_MODE" = "global" ]; then
        echo -e "Project: ${CYAN}$(pwd)${NC}"
    fi
    echo ""
    
    if [ -f "$STATE_FILE" ]; then
        STATE=$(jq -r '.state // "DISCOVER"' "$STATE_FILE")
        TIMESTAMP=$(jq -r '.timestamp // 0' "$STATE_FILE")
        
        # Format timestamp
        if [ "$TIMESTAMP" -ne 0 ]; then
            if [[ "$OSTYPE" == "darwin"* ]]; then
                START_TIME=$(date -r "$TIMESTAMP" "+%Y-%m-%d %H:%M:%S")
            else
                START_TIME=$(date -d "@$TIMESTAMP" "+%Y-%m-%d %H:%M:%S")
            fi
        else
            START_TIME="Unknown"
        fi
        
        # Calculate session duration
        NOW=$(date +%s)
        DURATION=$((NOW - TIMESTAMP))
        HOURS=$((DURATION / 3600))
        MINUTES=$(((DURATION % 3600) / 60))
        
        # State color and description
        case "$STATE" in
            UNLEASH)
                STATE_COLOR="${GREEN}UNLEASH${NC} ⚡"
                STATE_DESC="Full tool access - autonomous execution"
                ;;
            OPTIMIZE)
                STATE_COLOR="${YELLOW}OPTIMIZE${NC} 🤝"
                STATE_DESC="Collaborative mode - needs user input"
                ;;
            *)
                STATE_COLOR="${CYAN}DISCOVER${NC} 🔍"
                STATE_DESC="Analysis and planning - restricted tools"
                ;;
        esac
        
        echo -e "Current State: $STATE_COLOR"
        echo -e "Description:   $STATE_DESC"
        echo -e "Session Start: $START_TIME"
        echo -e "Duration:      ${HOURS}h ${MINUTES}m"
    else
        echo -e "State: ${YELLOW}Not initialized${NC}"
        echo "Run a state command to begin"
    fi
}

show_which() {
    echo -e "${BLUE}Cohesion Installation Info${NC}"
    echo "========================="
    echo -e "Using: ${YELLOW}$USING_MODE${NC} installation"
    
    case $USING_MODE in
        local)
            echo -e "Path: ${CYAN}$(pwd)/$LOCAL_CLAUDE_DIR${NC}"
            echo ""
            echo -e "${GREEN}Tip:${NC} To use Cohesion in all projects, run:"
            echo -e "  ${CYAN}cohesion upgrade --to-global${NC}"
            ;;
        global)
            echo -e "Installation: ${CYAN}$GLOBAL_COHESION_DIR${NC}"
            echo -e "Current project: ${CYAN}$(pwd)${NC}"
            local PROJECT_HASH=$(echo "$(pwd)" | shasum -a 256 | cut -c1-16)
            echo -e "State storage: ${CYAN}$GLOBAL_COHESION_DIR/states/$PROJECT_HASH${NC}"
            ;;
    esac
    
    # Check for both installations
    if [ -d "$LOCAL_CLAUDE_DIR" ] && [ -d "$GLOBAL_COHESION_DIR" ]; then
        echo ""
        echo -e "${YELLOW}Note:${NC} Both local and global installations detected."
        echo "Currently using: $USING_MODE"
        echo "To switch, use: cohesion use [local|global]"
    fi
}

upgrade_to_global() {
    if [ "$USING_MODE" != "local" ]; then
        echo -e "${YELLOW}Not using local installation.${NC}"
        echo "Nothing to upgrade."
        exit 0
    fi
    
    echo -e "${CYAN}Upgrading to global installation...${NC}"
    echo ""
    
    # Run the install script in upgrade mode
    if [ -f "./install.sh" ]; then
        ./install.sh --upgrade
    elif [ -f "$LOCAL_CLAUDE_DIR/install.sh" ]; then
        "$LOCAL_CLAUDE_DIR/install.sh" --upgrade
    else
        echo -e "${RED}Install script not found!${NC}"
        echo "Please download from: https://cohesion.dev/install"
        exit 1
    fi
}

list_projects() {
    if [ "$USING_MODE" != "global" ]; then
        echo -e "${YELLOW}This command only works with global installation.${NC}"
        exit 1
    fi
    
    echo -e "${BLUE}Projects with Cohesion states:${NC}"
    echo "=============================="
    
    PROJECTS_FILE="$GLOBAL_COHESION_DIR/states/projects.json"
    if [ -f "$PROJECTS_FILE" ]; then
        jq -r '.projects | to_entries[] | "• \(.value.path)"' "$PROJECTS_FILE"
    else
        echo "No projects found."
    fi
}

init_project() {
    # Initialize LOCAL Cohesion installation in current project
    if [ "$USING_MODE" != "global" ]; then
        echo -e "${YELLOW}Init only works with global installation.${NC}"
        echo "Run 'cohesion upgrade' first to install globally."
        exit 1
    fi
    
    # Check if already initialized
    if [ -d "./.claude/hooks" ] && [ -f "./.claude/settings.json" ]; then
        echo -e "${GREEN}✓${NC} Project already has local Cohesion installation"
        exit 0
    fi
    
    echo -e "${CYAN}Initializing local Cohesion for this project...${NC}"
    
    # Create .claude directory structure
    mkdir -p ./.claude/hooks ./.claude/state ./.claude/utils
    
    # Copy all hooks from global installation
    cp -r "$GLOBAL_COHESION_DIR/hooks/"* ./.claude/hooks/
    cp -r "$GLOBAL_COHESION_DIR/utils/"* ./.claude/utils/ 2>/dev/null || true
    
    # Create local settings.json using WORKING format (not experimental)
    cat > ./.claude/settings.json << 'EOF'
{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-use.sh",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/bash-validator.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/detect-intent.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
EOF
    
    # Initialize state
    echo '{"state": "DISCOVER", "timestamp": '$(date +%s)'}' > ./.claude/state/session.json
    
    # Create symlink to cohesion command for convenience
    ln -sf "$GLOBAL_COHESION_DIR/bin/cohesion" ./cohesion 2>/dev/null || true
    
    echo -e "${GREEN}✓${NC} Initialized local Cohesion installation in $(pwd)"
    echo ""
    echo "This project now has its own Cohesion installation."
    echo "Use './cohesion' or 'cohesion' to manage states."
    echo ""
    echo "Current state: DISCOVER"
}

uninstall_cohesion() {
    echo -e "${RED}Uninstall Cohesion${NC}"
    echo "===================="
    
    echo "What would you like to uninstall?"
    echo "1) Local installation only (this project)"
    echo "2) Global installation (all projects)"
    echo "3) Everything (local + global)"
    echo "4) Cancel"
    echo ""
    read -p "Choice [4]: " uninstall_choice
    uninstall_choice=${uninstall_choice:-4}
    
    case $uninstall_choice in
        1)
            if [ -d "$LOCAL_CLAUDE_DIR" ]; then
                rm -rf "$LOCAL_CLAUDE_DIR"
                rm -f "./cohesion"
                echo -e "${GREEN}✓${NC} Local installation removed"
            else
                echo "No local installation found."
            fi
            ;;
        2)
            if [ -d "$GLOBAL_COHESION_DIR" ]; then
                rm -rf "$GLOBAL_COHESION_DIR"
                # Remove PATH entry
                echo -e "${YELLOW}Note:${NC} Remove this line from your shell config:"
                echo "  export PATH=\"\$PATH:$GLOBAL_COHESION_DIR/bin\""
                echo -e "${GREEN}✓${NC} Global installation removed"
            else
                echo "No global installation found."
            fi
            ;;
        3)
            rm -rf "$LOCAL_CLAUDE_DIR" 2>/dev/null || true
            rm -f "./cohesion" 2>/dev/null || true
            rm -rf "$GLOBAL_COHESION_DIR" 2>/dev/null || true
            echo -e "${GREEN}✓${NC} All Cohesion installations removed"
            ;;
        *)
            echo "Cancelled."
            ;;
    esac
}

validate_installation() {
    echo -e "${CYAN}Cohesion Installation Validation${NC}\n"
    
    local MODE=$(detect_mode)
    local ERRORS=0
    local WARNINGS=0
    
    echo -e "Installation Mode: ${YELLOW}$MODE${NC}"
    
    if [ "$MODE" = "none" ]; then
        echo -e "${RED}❌ No Cohesion installation found${NC}"
        echo "Run './install.sh' to install Cohesion"
        exit 1
    fi
    
    # Determine paths based on mode
    local SETTINGS_FILE HOOKS_DIR STATE_UTIL
    if [ "$MODE" = "local" ]; then
        SETTINGS_FILE="$LOCAL_CLAUDE_DIR/settings.json"
        HOOKS_DIR="$LOCAL_CLAUDE_DIR/hooks"
        STATE_UTIL="$LOCAL_CLAUDE_DIR/utils/state.sh"
    else
        SETTINGS_FILE="$GLOBAL_CLAUDE_DIR/settings.json"
        HOOKS_DIR="$GLOBAL_COHESION_DIR/hooks"
        STATE_UTIL="$GLOBAL_COHESION_DIR/utils/state.sh"
    fi
    
    echo ""
    echo -e "${BLUE}Configuration Files:${NC}"
    
    # Check settings.json
    if [ -f "$SETTINGS_FILE" ]; then
        if jq . "$SETTINGS_FILE" >/dev/null 2>&1; then
            echo -e "✅ settings.json - Valid JSON"
            # Check if it uses correct format
            if jq -e '.hooks' "$SETTINGS_FILE" >/dev/null 2>&1; then
                echo -e "✅ settings.json - Correct hook format"
            else
                echo -e "⚠️  settings.json - Old format detected"
                ((WARNINGS++))
            fi
        else
            echo -e "❌ settings.json - Invalid JSON"
            ((ERRORS++))
        fi
    else
        echo -e "❌ settings.json - Missing"
        ((ERRORS++))
    fi
    
    echo ""
    echo -e "${BLUE}Hook Files:${NC}"
    
    # Check critical hooks
    local HOOKS=("pre-tool-use.sh" "post-tool-use.sh" "detect-intent.sh" "session-start.sh" "session-end.sh")
    for hook in "${HOOKS[@]}"; do
        local hook_path="$HOOKS_DIR/$hook"
        if [ -f "$hook_path" ]; then
            if [ -x "$hook_path" ]; then
                echo -e "✅ $hook - Exists and executable"
            else
                echo -e "⚠️  $hook - Exists but not executable"
                ((WARNINGS++))
            fi
        else
            echo -e "❌ $hook - Missing"
            ((ERRORS++))
        fi
    done
    
    echo ""
    echo -e "${BLUE}State Management:${NC}"
    
    # Check state utility
    if [ -f "$STATE_UTIL" ] && [ -x "$STATE_UTIL" ]; then
        echo -e "✅ state.sh - Available"
        
        # Test state operations
        if current_state=$("$STATE_UTIL" get 2>/dev/null); then
            echo -e "✅ State system - Working (Current: $current_state)"
        else
            echo -e "⚠️  State system - Error reading state"
            ((WARNINGS++))
        fi
    else
        echo -e "❌ state.sh - Missing or not executable"
        ((ERRORS++))
    fi
    
    echo ""
    echo -e "${BLUE}Hook Integration Test:${NC}"
    
    # Test detect-intent.sh specifically
    if [ -f "$HOOKS_DIR/detect-intent.sh" ] && [ -x "$HOOKS_DIR/detect-intent.sh" ]; then
        test_result=$(echo '{"prompt": "test validation"}' | "$HOOKS_DIR/detect-intent.sh" 2>&1)
        if echo "$test_result" | grep -q '"continue": true'; then
            echo -e "✅ detect-intent.sh - Responding correctly"
        else
            echo -e "⚠️  detect-intent.sh - Unexpected response:"
            echo "    $test_result"
            ((WARNINGS++))
        fi
    fi
    
    echo ""
    echo -e "${BLUE}Summary:${NC}"
    if [ $ERRORS -eq 0 ] && [ $WARNINGS -eq 0 ]; then
        echo -e "${GREEN}🎉 Perfect! Cohesion installation is fully functional${NC}"
    elif [ $ERRORS -eq 0 ]; then
        echo -e "${YELLOW}⚠️  Installation working with $WARNINGS warning(s)${NC}"
        echo "Consider running './install.sh' to refresh the installation"
    else
        echo -e "${RED}❌ Installation has $ERRORS error(s) and $WARNINGS warning(s)${NC}"
        echo "Run './install.sh' to fix the installation"
        exit 1
    fi
}

show_debug_info() {
    echo -e "${CYAN}Cohesion Debug Information${NC}\n"
    
    local MODE=$(detect_mode)
    echo -e "Mode: ${YELLOW}$MODE${NC}"
    
    echo ""
    echo -e "${BLUE}Environment:${NC}"
    echo "Working Directory: $(pwd)"
    echo "User: $(whoami)"
    echo "Shell: $SHELL"
    echo "Date: $(date)"
    
    echo ""
    echo -e "${BLUE}Installation Paths:${NC}"
    echo "Global Cohesion: $GLOBAL_COHESION_DIR ($([ -d "$GLOBAL_COHESION_DIR" ] && echo "exists" || echo "missing"))"
    echo "Global Claude: $GLOBAL_CLAUDE_DIR ($([ -d "$GLOBAL_CLAUDE_DIR" ] && echo "exists" || echo "missing"))"
    echo "Local Claude: $LOCAL_CLAUDE_DIR ($([ -d "$LOCAL_CLAUDE_DIR" ] && echo "exists" || echo "missing"))"
    
    echo ""
    echo -e "${BLUE}Active Configuration:${NC}"
    if [ "$MODE" != "none" ]; then
        local SETTINGS_FILE HOOKS_DIR STATE_FILE
        if [ "$MODE" = "local" ]; then
            SETTINGS_FILE="$LOCAL_CLAUDE_DIR/settings.json"
            HOOKS_DIR="$LOCAL_CLAUDE_DIR/hooks"
            STATE_FILE="$LOCAL_CLAUDE_DIR/state/session.json"
        else
            SETTINGS_FILE="$GLOBAL_CLAUDE_DIR/settings.json"
            HOOKS_DIR="$GLOBAL_COHESION_DIR/hooks"
            PROJECT_HASH=$(pwd | shasum -a 256 | cut -c1-16)
            STATE_FILE="$GLOBAL_COHESION_DIR/states/$PROJECT_HASH/session.json"
        fi
        
        echo "Settings: $SETTINGS_FILE"
        echo "Hooks: $HOOKS_DIR"
        echo "State File: $STATE_FILE"
        
        if [ -f "$STATE_FILE" ]; then
            echo "Current State: $(jq -r '.state // "unknown"' "$STATE_FILE" 2>/dev/null || echo "error reading")"
        fi
    fi
    
    echo ""
    echo -e "${BLUE}Log Files:${NC}"
    local log_files=(/tmp/cohesion*.log)
    if [ -f "${log_files[0]}" ]; then
        for log in "${log_files[@]}"; do
            if [ -f "$log" ]; then
                echo "$log ($(wc -l < "$log") lines)"
            fi
        done
        echo ""
        echo -e "${YELLOW}Recent log entries:${NC}"
        tail -5 /tmp/cohesion*.log 2>/dev/null | head -20
    else
        echo "No log files found"
    fi
}

# Main command handling
case "${1:-help}" in
    status|s)
        show_status
        ;;
    duo-status)
        show_duo_status
        ;;
    reset|r)
        duo_reset
        ;;
    safety-check)
        safety_check
        ;;
    protection-status)
        protection_status
        ;;
    which|w)
        show_which
        ;;
    upgrade)
        upgrade_to_global
        ;;
    list|ls)
        list_projects
        ;;
    init)
        init_project
        ;;
    uninstall)
        uninstall_cohesion
        ;;
    validate)
        validate_installation
        ;;
    debug)
        show_debug_info
        ;;
    help|h|--help|-h)
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command:${NC} $1"
        echo "Run 'cohesion help' for usage"
        exit 1
        ;;
esac